# Kitty Startup Session

# Tab 1: util - pgcli in its own tmux session
new_tab util
cd ~
launch /opt/homebrew/bin/fish -l -C "tmux new-session -A -s util 'pgcli -h localhost -U $(whoami) cword'"

# Tab 2: terminal - fish shell in cwordweb in its own tmux session
new_tab terminal
cd ~
launch /opt/homebrew/bin/fish -l -C "tmux new-session -A -s terminal -c ~/src/cwordweb"

# Tab 3: vim - vim in cwordweb in its own tmux session
new_tab vim
cd ~
launch /opt/homebrew/bin/fish -l -C "tmux new-session -A -s vim -c ~/src/cwordweb 'vim'"

# Tab 4: agent - claude in cwordweb in its own tmux session
new_tab agent
cd ~
launch /opt/homebrew/bin/fish -l -C "tmux new-session -A -s agent -c ~/src/cwordweb 'claude'"
